{
  "name": "visepanda-platform",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down -v",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "docker:check": "docker compose -f infra/docker/docker-compose.yml config >/dev/null"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
