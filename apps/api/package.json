{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @visepanda/shared-types build && pnpm --filter @visepanda/domain-auth build && pnpm --filter @visepanda/domain-content build && pnpm --filter @visepanda/domain-ai build && pnpm --filter @visepanda/domain-trip build",
    "build": "nest build",
    "pretest": "pnpm --filter @visepanda/shared-types build && pnpm --filter @visepanda/domain-auth build && pnpm --filter @visepanda/domain-content build && pnpm --filter @visepanda/domain-ai build && pnpm --filter @visepanda/domain-trip build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "tsc --noEmit",
    "test": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --config ./test/jest-e2e.json --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@visepanda/domain-ai": "workspace:*",
    "@visepanda/domain-auth": "workspace:*",
    "@visepanda/domain-content": "workspace:*",
    "@visepanda/domain-trip": "workspace:*",
    "@visepanda/shared-types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
