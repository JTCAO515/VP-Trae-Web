#
# VisePanda 平台环境变量示例
# - 建议做法：
#   - 本地：复制为 `.env.local`（或按各应用约定的 .env 文件名）
#   - 预发布：在 CI/部署系统中注入（GitHub Actions Secrets / K8s Secret / Render/Vercel env 等）
#   - 生产：同上，且必须使用独立的密钥、DB、Redis、对象存储桶
#

# -----------------------------
# 环境区分：local / staging / production
# -----------------------------
VISEPANDA_ENV=local
NODE_ENV=development

# API 端口（apps/api 默认 3000）
PORT=3000

# -----------------------------
# 数据库（PostgreSQL）
# -----------------------------
# local：通常来自 infra/docker/docker-compose.yml
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=visepanda
POSTGRES_USER=visepanda
POSTGRES_PASSWORD=visepanda
DATABASE_URL=postgresql://visepanda:visepanda@127.0.0.1:5432/visepanda?schema=public

# staging/production 示例（按实际托管方替换）：
# POSTGRES_HOST=your-managed-postgres.example.com
# POSTGRES_PORT=5432
# POSTGRES_DB=visepanda_staging
# POSTGRES_USER=visepanda_staging
# POSTGRES_PASSWORD=********
# DATABASE_URL=postgresql://visepanda_staging:********@your-managed-postgres.example.com:5432/visepanda_staging?schema=public

# -----------------------------
# Redis
# -----------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# staging/production 示例（如使用 TLS/集群形态，可直接提供 provider 的连接串）：
# REDIS_URL=rediss://:********@your-managed-redis.example.com:6380

# -----------------------------
# 对象存储（S3 / OSS 兼容）
# -----------------------------
# local：推荐用 MinIO
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=visepanda-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/visepanda-local

# 仅本地 minio console 用（参见 infra/docker/docker-compose.yml）
MINIO_CONSOLE_PORT=9001

# staging/production 示例（AWS S3 / 阿里云 OSS / 腾讯 COS 等）：
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=ap-southeast-1
# S3_BUCKET=visepanda-prod
# S3_ACCESS_KEY=********
# S3_SECRET_KEY=********
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_BASE_URL=https://visepanda-prod.s3.amazonaws.com

# -----------------------------
# AI / 模型配置（domain-ai 的运行时配置约定）
# -----------------------------
# 说明：
# - 当前代码默认使用 mock provider 跑通闭环；以下变量用于进入真实模型接入阶段的配置落点。
# - 建议在 staging 先接入真实 provider，并通过路由策略逐步放量到 production。

# 开关：mock / real（TODO：当接入真实 Provider 时由代码读取）
AI_RUNTIME_MODE=mock

# Provider 侧密钥（真实接入时启用）
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_GOOGLE_API_KEY=

# 默认模型名示例（真实接入时启用）
AI_MODEL_CHAT_PRIMARY=gpt-4o-mini
AI_MODEL_TRIP_PRIMARY=gpt-4o-mini
AI_MODEL_TRIP_FALLBACK=claude-3-5-sonnet

# 路由策略（与 docs/architecture/ai-routing.md 中 route name 对齐）
AI_ROUTE_CHAT_DEFAULT=chat_travel_advice.default
AI_ROUTE_TRIP_DEFAULT=trip_planning.default
